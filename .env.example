# Smart Locker Encryption Key (32 bytes, base64-encoded)
# Generate with: python -m scripts.generate_key
SMART_LOCKER_ENC_KEY=

# Smart Locker HMAC Key (32 bytes, base64-encoded)
# Generate with: python -m scripts.generate_key
SMART_LOCKER_HMAC_KEY=

# Database path (default: smart_locker.db in project root)
SMART_LOCKER_DB_PATH=smart_locker.db

# NFC Reader name substring filter
SMART_LOCKER_READER_NAME=ACR1252

# Session timeout in seconds (default: 120)
SMART_LOCKER_SESSION_TIMEOUT=120

# Maximum concurrent borrows per user (default: 5)
SMART_LOCKER_MAX_BORROWS=5

# Excel export file path — used by CLI scripts (e.g., update_device.py)
# The old automatic sync is replaced by the web dashboard and admin download endpoint
SMART_LOCKER_EXCEL_PATH=smart_locker_data.xlsx

# FastAPI server bind address (default: 0.0.0.0)
SMART_LOCKER_API_HOST=0.0.0.0

# FastAPI server port (default: 8000)
SMART_LOCKER_API_PORT=8000

# Source Excel — company device master list on OneDrive (path to .xlsx)
# Leave empty to disable automatic daily import
SMART_LOCKER_SOURCE_EXCEL_PATH=

# Daily source import schedule, 24h format (default: 06:00)
SMART_LOCKER_SOURCE_SYNC_HOUR=6
SMART_LOCKER_SOURCE_SYNC_MINUTE=0

# Photo input folder — drop device photos here, filename = model number
# (e.g., "87V.jpg" applies to all devices with model "87V"). Leave empty to disable.
SMART_LOCKER_PHOTO_INPUT_PATH=
