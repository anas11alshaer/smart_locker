# Smart Locker Encryption Key (32 bytes, base64-encoded)
# Generate with: python -m scripts.generate_key
SMART_LOCKER_ENC_KEY=

# Smart Locker HMAC Key (32 bytes, base64-encoded)
# Generate with: python -m scripts.generate_key
SMART_LOCKER_HMAC_KEY=

# Database path (default: smart_locker.db in project root)
SMART_LOCKER_DB_PATH=smart_locker.db

# NFC Reader name substring filter
SMART_LOCKER_READER_NAME=ACR1252

# Session timeout in seconds (default: 120)
SMART_LOCKER_SESSION_TIMEOUT=120
